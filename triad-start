#!/usr/bin/env bash
set -euo pipefail

CONDUCTOR_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_PROJECTS_HOME="/Users/daniyarserikson/Projects"
PROJECTS_HOME="${TRIAD_PROJECTS_HOME:-$DEFAULT_PROJECTS_HOME}"
PYTHON_BIN="$CONDUCTOR_ROOT/.venv/bin/python"
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="${PYTHON:-python3}"
fi

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: triad-start [project_description.md] [--project-name NAME] [--dry-run]"
  echo "Default behavior: creates/uses a project folder under $DEFAULT_PROJECTS_HOME."
  echo "If no markdown file is passed, it auto-uses project.md or the only .md file in the current folder."
  echo "Options:"
  echo "  --project-name NAME     Explicit project folder name"
  echo "  --projects-home PATH    Override projects root (default: $DEFAULT_PROJECTS_HOME)"
  echo "  --use-current-dir       Use current directory as project root (legacy behavior)"
  echo "Env:"
  echo "  TRIAD_PROJECTS_HOME     Default projects root (same as --projects-home)"
  exit 0
fi

TASK_PATH=""
PROJECT_NAME=""
USE_CURRENT_DIR=0
EXTRA_ARGS=()
i=1
while [[ $i -le $# ]]; do
  arg="${!i}"
  if [[ "$arg" == "--project-name" ]]; then
    ((i++))
    if [[ $i -gt $# ]]; then
      echo "Missing value for --project-name"
      exit 2
    fi
    PROJECT_NAME="${!i}"
  elif [[ "$arg" == "--projects-home" ]]; then
    ((i++))
    if [[ $i -gt $# ]]; then
      echo "Missing value for --projects-home"
      exit 2
    fi
    PROJECTS_HOME="${!i}"
  elif [[ "$arg" == "--use-current-dir" ]]; then
    USE_CURRENT_DIR=1
  elif [[ "$arg" == --* ]]; then
    EXTRA_ARGS+=("$arg")
  elif [[ -z "$TASK_PATH" ]]; then
    TASK_PATH="$arg"
  else
    EXTRA_ARGS+=("$arg")
  fi
  ((i++))
done

if [[ -z "$TASK_PATH" ]]; then
  if [[ -f "project.md" ]]; then
    TASK_PATH="project.md"
  elif [[ -f "PROJECT.md" ]]; then
    TASK_PATH="PROJECT.md"
  else
    mapfile -t MD_FILES < <(find . -maxdepth 1 -type f -name "*.md" | sed 's|^\./||' | sort)
    if [[ "${#MD_FILES[@]}" -eq 1 ]]; then
      TASK_PATH="${MD_FILES[0]}"
    else
      echo "Usage: $0 <project_description.md>"
      echo "Tip: create project.md, then run $0"
      exit 2
    fi
  fi
fi

if [[ ! -f "$TASK_PATH" ]]; then
  echo "Task file not found: $TASK_PATH"
  exit 2
fi

TASK_PATH_ABS="$(cd "$(dirname "$TASK_PATH")" && pwd)/$(basename "$TASK_PATH")"

if [[ "$USE_CURRENT_DIR" -eq 1 ]]; then
  PROJECT_ROOT="$(pwd)"
else
  if [[ -z "$PROJECT_NAME" ]]; then
    PROJECT_NAME="$(awk '/^#/{sub(/^# +/,""); print; exit}' "$TASK_PATH_ABS" | tr -d '\r' || true)"
  fi
  if [[ -z "$PROJECT_NAME" ]]; then
    PROJECT_NAME="$(basename "$TASK_PATH_ABS")"
    PROJECT_NAME="${PROJECT_NAME%.md}"
  fi
  PROJECT_NAME="$(printf '%s' "$PROJECT_NAME" | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
  PROJECT_DIR_NAME="$(printf '%s' "$PROJECT_NAME" | sed -E 's#[/\\]+#-#g; s/[[:space:]]+/-/g')"
  if [[ -z "$PROJECT_DIR_NAME" ]]; then
    PROJECT_DIR_NAME="project_$(date -u +%Y%m%d_%H%M%SZ)"
  fi

  PROJECT_ROOT="$PROJECTS_HOME/$PROJECT_DIR_NAME"
  mkdir -p "$PROJECT_ROOT"

  TARGET_TASK_PATH="$PROJECT_ROOT/project.md"
  if [[ "$TASK_PATH_ABS" != "$TARGET_TASK_PATH" ]]; then
    cp "$TASK_PATH_ABS" "$TARGET_TASK_PATH"
  fi
  TASK_PATH="$TARGET_TASK_PATH"
fi

cd "$PROJECT_ROOT"
RUN_ID="run_$(date -u +%Y%m%d_%H%M%SZ)"
CONFIG_PATH="$CONDUCTOR_ROOT/config.yaml"

# Bootstrap git repo if needed so conductor worktrees/branches can run.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "No git repository found. Initializing one in $PROJECT_ROOT..."
  git init -b main >/dev/null
fi

if ! git show-ref --verify --quiet refs/heads/main; then
  CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [[ -n "$CURRENT_BRANCH" && "$CURRENT_BRANCH" != "HEAD" ]]; then
    git branch main "$CURRENT_BRANCH" >/dev/null 2>&1 || true
  fi
fi

if ! git rev-parse HEAD >/dev/null 2>&1; then
  if ! git config user.email >/dev/null 2>&1; then
    git config user.email "triad@local"
  fi
  if ! git config user.name >/dev/null 2>&1; then
    git config user.name "Triad Conductor"
  fi
  git add -A
  git commit --allow-empty -m "Initial commit for Triad Conductor run" >/dev/null
fi

echo "Starting Triad Conductor"
echo "Project root: $PROJECT_ROOT"
echo "Task file: $TASK_PATH"
echo "Run id: $RUN_ID"

exec "$PYTHON_BIN" "$CONDUCTOR_ROOT/conductor.py" run \
  --task "$TASK_PATH" \
  --config "$CONFIG_PATH" \
  --project-root "$PROJECT_ROOT" \
  --run-id "$RUN_ID" \
  "${EXTRA_ARGS[@]}"
