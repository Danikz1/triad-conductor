#!/usr/bin/env bash
set -euo pipefail

CONDUCTOR_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_PROJECTS_HOME="/Users/daniyarserikson/Projects"
PROJECTS_HOME="${TRIAD_PROJECTS_HOME:-$DEFAULT_PROJECTS_HOME}"
PYTHON_BIN="$CONDUCTOR_ROOT/.venv/bin/python"
if [[ ! -x "$PYTHON_BIN" ]]; then
  PYTHON_BIN="${PYTHON:-python3}"
fi
SKIP_PREFLIGHT=0
PREFLIGHT_ONLY=0
SKIP_AUTH_PREFLIGHT=0

_first_line() {
  sed -n '1p'
}

_version_line() {
  local cmd="$1"
  local out=""
  out="$("$cmd" --version 2>/dev/null | _first_line || true)"
  if [[ -z "$out" ]]; then
    out="$("$cmd" -v 2>/dev/null | _first_line || true)"
  fi
  if [[ -z "$out" ]]; then
    out="version unknown"
  fi
  printf '%s' "$out"
}

_run_preflight() {
  local missing=0
  local auth_missing=0
  echo "Preflight checks:"

  if command -v git >/dev/null 2>&1; then
    echo "  [OK] git: $(_version_line git)"
  else
    echo "  [MISSING] git"
    missing=1
  fi

  if command -v "$PYTHON_BIN" >/dev/null 2>&1; then
    echo "  [OK] python: $("$PYTHON_BIN" --version 2>&1 | _first_line)"
  else
    echo "  [MISSING] python runtime: $PYTHON_BIN"
    missing=1
  fi

  if command -v claude >/dev/null 2>&1; then
    local claude_help=""
    claude_help="$(claude --help 2>&1 || true)"
    if echo "$claude_help" | grep -q -- "--dangerously-skip-permissions"; then
      echo "  [OK] claude: $(_version_line claude)"
    else
      echo "  [WARN] claude: found ($(_version_line claude)), automation flag may be unsupported"
    fi
  else
    echo "  [MISSING] claude CLI"
    missing=1
  fi

  if command -v codex >/dev/null 2>&1; then
    local codex_help=""
    codex_help="$(codex exec --help 2>&1 || true)"
    if echo "$codex_help" | grep -q -- "--full-auto"; then
      echo "  [OK] codex: $(_version_line codex) (has --full-auto fallback)"
    elif echo "$codex_help" | grep -q -- "--sandbox"; then
      echo "  [OK] codex: $(_version_line codex) (has --sandbox mode)"
    else
      echo "  [WARN] codex: found ($(_version_line codex)), no known automation flags in help"
    fi
  else
    echo "  [MISSING] codex CLI"
    missing=1
  fi

  if command -v gemini >/dev/null 2>&1; then
    local gemini_help=""
    gemini_help="$(gemini --help 2>&1 || true)"
    if echo "$gemini_help" | grep -q -- "--approval-mode"; then
      echo "  [OK] gemini: $(_version_line gemini) (supports --approval-mode)"
    elif echo "$gemini_help" | grep -q -- "--yolo"; then
      echo "  [OK] gemini: $(_version_line gemini) (supports --yolo)"
    else
      echo "  [WARN] gemini: found ($(_version_line gemini)), no known automation flags in help"
    fi
  else
    echo "  [MISSING] gemini CLI"
    missing=1
  fi

  if [[ "$SKIP_AUTH_PREFLIGHT" -eq 0 ]]; then
    if [[ -f "$CONDUCTOR_ROOT/config.yaml" ]]; then
      local auth_out=""
      if auth_out="$("$PYTHON_BIN" - "$CONDUCTOR_ROOT/config.yaml" 2>&1 <<'PY'
from pathlib import Path
import sys

from conductor.config import load_config
from conductor.models.preflight import ensure_required_auth

cfg = load_config(Path(sys.argv[1]))
try:
    ensure_required_auth(cfg)
except RuntimeError as exc:
    print(exc)
    raise SystemExit(1)
PY
)"; then
        echo "  [OK] model auth preflight"
      else
        echo "  [AUTH MISSING] model auth preflight failed:"
        while IFS= read -r line; do
          [[ -n "$line" ]] && echo "    $line"
        done <<< "$auth_out"
        auth_missing=1
      fi
    else
      echo "  [WARN] config not found for auth preflight: $CONDUCTOR_ROOT/config.yaml"
    fi
  else
    echo "  [SKIPPED] auth preflight (--skip-auth-preflight)"
  fi

  if [[ "$missing" -ne 0 || "$auth_missing" -ne 0 ]]; then
    echo "Preflight failed: install missing tools and complete CLI authentication before running triad-start."
    return 3
  fi

  echo "Preflight passed."
  return 0
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: triad-start [project_description.md] [--project-name NAME] [--dry-run]"
  echo "Default behavior: creates/uses a project folder under $DEFAULT_PROJECTS_HOME."
  echo "If no markdown file is passed, it auto-uses project.md or the only .md file in the current folder."
  echo "Options:"
  echo "  --project-name NAME     Explicit project folder name"
  echo "  --projects-home PATH    Override projects root (default: $DEFAULT_PROJECTS_HOME)"
  echo "  --use-current-dir       Use current directory as project root (legacy behavior)"
  echo "  --skip-preflight        Skip environment preflight checks"
  echo "  --skip-auth-preflight   Skip authentication checks (also forwarded to conductor.py)"
  echo "  --preflight-only        Run preflight checks and exit"
  echo "Env:"
  echo "  TRIAD_PROJECTS_HOME     Default projects root (same as --projects-home)"
  exit 0
fi

TASK_PATH=""
PROJECT_NAME=""
USE_CURRENT_DIR=0
EXTRA_ARGS=()
i=1
while [[ $i -le $# ]]; do
  arg="${!i}"
  if [[ "$arg" == "--project-name" ]]; then
    ((i++))
    if [[ $i -gt $# ]]; then
      echo "Missing value for --project-name"
      exit 2
    fi
    PROJECT_NAME="${!i}"
  elif [[ "$arg" == "--projects-home" ]]; then
    ((i++))
    if [[ $i -gt $# ]]; then
      echo "Missing value for --projects-home"
      exit 2
    fi
    PROJECTS_HOME="${!i}"
  elif [[ "$arg" == "--use-current-dir" ]]; then
    USE_CURRENT_DIR=1
  elif [[ "$arg" == "--skip-preflight" ]]; then
    SKIP_PREFLIGHT=1
  elif [[ "$arg" == "--skip-auth-preflight" ]]; then
    SKIP_AUTH_PREFLIGHT=1
    EXTRA_ARGS+=("$arg")
  elif [[ "$arg" == "--preflight-only" ]]; then
    PREFLIGHT_ONLY=1
  elif [[ "$arg" == --* ]]; then
    EXTRA_ARGS+=("$arg")
    if [[ "$arg" == "--run-id" || "$arg" == "--config" || "$arg" == "--project-root" ]]; then
      ((i++))
      if [[ $i -gt $# ]]; then
        echo "Missing value for $arg"
        exit 2
      fi
      EXTRA_ARGS+=("${!i}")
    fi
  elif [[ -z "$TASK_PATH" ]]; then
    TASK_PATH="$arg"
  else
    EXTRA_ARGS+=("$arg")
  fi
  ((i++))
done

if [[ "$SKIP_PREFLIGHT" -eq 0 ]]; then
  _run_preflight || exit $?
elif [[ "$PREFLIGHT_ONLY" -eq 1 ]]; then
  echo "--preflight-only cannot be combined with --skip-preflight"
  exit 2
fi

if [[ "$PREFLIGHT_ONLY" -eq 1 ]]; then
  exit 0
fi

if [[ -z "$TASK_PATH" ]]; then
  if [[ -f "project.md" ]]; then
    TASK_PATH="project.md"
  elif [[ -f "PROJECT.md" ]]; then
    TASK_PATH="PROJECT.md"
  else
    MD_FILES=()
    while IFS= read -r file; do
      MD_FILES+=("$file")
    done < <(find . -maxdepth 1 -type f -name "*.md" | sed 's|^\./||' | sort)
    if [[ "${#MD_FILES[@]}" -eq 1 ]]; then
      TASK_PATH="${MD_FILES[0]}"
    else
      echo "Usage: $0 <project_description.md>"
      echo "Tip: create project.md, then run $0"
      exit 2
    fi
  fi
fi

if [[ ! -f "$TASK_PATH" ]]; then
  echo "Task file not found: $TASK_PATH"
  exit 2
fi

TASK_PATH_ABS="$(cd "$(dirname "$TASK_PATH")" && pwd)/$(basename "$TASK_PATH")"

if [[ "$USE_CURRENT_DIR" -eq 1 ]]; then
  PROJECT_ROOT="$(pwd)"
else
  if [[ -z "$PROJECT_NAME" ]]; then
    PROJECT_NAME="$(awk '/^#/{sub(/^# +/,""); print; exit}' "$TASK_PATH_ABS" | tr -d '\r' || true)"
  fi
  if [[ -z "$PROJECT_NAME" ]]; then
    PROJECT_NAME="$(basename "$TASK_PATH_ABS")"
    PROJECT_NAME="${PROJECT_NAME%.md}"
  fi
  PROJECT_NAME="$(printf '%s' "$PROJECT_NAME" | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
  PROJECT_DIR_NAME="$(printf '%s' "$PROJECT_NAME" | sed -E 's#[/\\]+#-#g; s/[[:space:]]+/-/g')"
  if [[ -z "$PROJECT_DIR_NAME" ]]; then
    PROJECT_DIR_NAME="project_$(date -u +%Y%m%d_%H%M%SZ)"
  fi

  PROJECT_ROOT="$PROJECTS_HOME/$PROJECT_DIR_NAME"
  mkdir -p "$PROJECT_ROOT"

  TARGET_TASK_PATH="$PROJECT_ROOT/project.md"
  if [[ "$TASK_PATH_ABS" != "$TARGET_TASK_PATH" ]]; then
    cp "$TASK_PATH_ABS" "$TARGET_TASK_PATH"
  fi
  TASK_PATH="$TARGET_TASK_PATH"
fi

cd "$PROJECT_ROOT"
RUN_ID="run_$(date -u +%Y%m%d_%H%M%SZ)"
CONFIG_PATH="$CONDUCTOR_ROOT/config.yaml"

# Bootstrap git repo if needed so conductor worktrees/branches can run.
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "No git repository found. Initializing one in $PROJECT_ROOT..."
  git init -b main >/dev/null
fi

if ! git show-ref --verify --quiet refs/heads/main; then
  CURRENT_BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
  if [[ -n "$CURRENT_BRANCH" && "$CURRENT_BRANCH" != "HEAD" ]]; then
    git branch main "$CURRENT_BRANCH" >/dev/null 2>&1 || true
  fi
fi

if ! git rev-parse HEAD >/dev/null 2>&1; then
  if ! git config user.email >/dev/null 2>&1; then
    git config user.email "triad@local"
  fi
  if ! git config user.name >/dev/null 2>&1; then
    git config user.name "Triad Conductor"
  fi
  git add -A
  git commit --allow-empty -m "Initial commit for Triad Conductor run" >/dev/null
fi

echo "Starting Triad Conductor"
echo "Project root: $PROJECT_ROOT"
echo "Task file: $TASK_PATH"
echo "Run id: $RUN_ID"

exec "$PYTHON_BIN" "$CONDUCTOR_ROOT/conductor.py" run \
  --task "$TASK_PATH" \
  --config "$CONFIG_PATH" \
  --project-root "$PROJECT_ROOT" \
  --run-id "$RUN_ID" \
  ${EXTRA_ARGS[@]+"${EXTRA_ARGS[@]}"}
