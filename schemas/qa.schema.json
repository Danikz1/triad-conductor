{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TriadConductorQA",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "agent",
    "verdict",
    "concerns",
    "tests_to_add",
    "repro_notes"
  ],
  "properties": {
    "kind": {
      "const": "qa"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "CONCERNS",
        "BLOCKED"
      ]
    },
    "concerns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "severity",
          "evidence",
          "suggested_test_or_fix"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "evidence": {
            "type": "string",
            "minLength": 10
          },
          "suggested_test_or_fix": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "tests_to_add": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "purpose",
          "command",
          "code_snippet"
        ],
        "properties": {
          "purpose": {
            "type": "string",
            "minLength": 5
          },
          "command": {
            "type": "string",
            "minLength": 2
          },
          "code_snippet": {
            "type": "string",
            "minLength": 10
          }
        }
      }
    },
    "repro_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
