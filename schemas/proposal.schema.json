{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TriadConductorProposal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "agent",
    "approach_summary",
    "acceptance_criteria",
    "plan",
    "tests",
    "risks",
    "unknowns",
    "rollback",
    "tournament_recommended"
  ],
  "properties": {
    "kind": {
      "const": "proposal"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string"
        }
      }
    },
    "approach_summary": {
      "type": "string",
      "minLength": 20
    },
    "acceptance_criteria": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "must",
        "should",
        "could"
      ],
      "properties": {
        "must": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          }
        },
        "should": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          }
        },
        "could": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "plan": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "outputs"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "description": {
            "type": "string",
            "minLength": 10
          },
          "likely_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 3
            }
          }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commands",
        "notes"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "severity",
          "title",
          "detail",
          "mitigation"
        ],
        "properties": {
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "title": {
            "type": "string",
            "minLength": 3
          },
          "detail": {
            "type": "string",
            "minLength": 10
          },
          "mitigation": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "rollback": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "tournament_recommended": {
      "type": "boolean"
    },
    "tournament_reason": {
      "type": "string"
    },
    "spec_contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "quote",
          "why_conflicts",
          "resolution_options"
        ],
        "properties": {
          "quote": {
            "type": "string",
            "minLength": 5
          },
          "why_conflicts": {
            "type": "string",
            "minLength": 10
          },
          "resolution_options": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 5
            }
          }
        }
      }
    },
    "estimated_effort": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "complexity": {
          "type": "string",
          "enum": [
            "S",
            "M",
            "L",
            "XL"
          ]
        },
        "time_minutes_range": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 2,
          "maxItems": 2
        },
        "cost_usd_range": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0
          },
          "minItems": 2,
          "maxItems": 2
        }
      }
    }
  }
}
