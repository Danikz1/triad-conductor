{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TriadConductorBlockedReport",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "run_id",
    "status",
    "block_reason",
    "evidence",
    "what_was_tried",
    "spec_change_options"
  ],
  "properties": {
    "kind": {
      "const": "blocked_report"
    },
    "run_id": {
      "type": "string",
      "minLength": 6
    },
    "status": {
      "type": "string",
      "enum": [
        "BLOCKED"
      ]
    },
    "block_reason": {
      "type": "string",
      "minLength": 10
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 10
      }
    },
    "what_was_tried": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "spec_change_options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "option",
          "pros",
          "cons",
          "impact"
        ],
        "properties": {
          "option": {
            "type": "string",
            "minLength": 10
          },
          "pros": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "cons": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 3
            }
          },
          "impact": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    }
  }
}
