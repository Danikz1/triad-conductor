{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TriadConductorReview",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "agent",
    "verdict",
    "blockers",
    "requested_changes",
    "non_blocking_notes",
    "scope_creep"
  ],
  "properties": {
    "kind": {
      "const": "review"
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "model"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "APPROVE",
        "REQUEST_CHANGES",
        "BLOCKED"
      ]
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "title",
          "evidence",
          "why_it_matters",
          "suggested_fix"
        ],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 3
          },
          "evidence": {
            "type": "string",
            "minLength": 10
          },
          "why_it_matters": {
            "type": "string",
            "minLength": 10
          },
          "suggested_fix": {
            "type": "string",
            "minLength": 5
          },
          "patch_unified_diff": {
            "type": "string"
          }
        }
      }
    },
    "requested_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 5
      }
    },
    "non_blocking_notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "scope_creep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected",
        "notes"
      ],
      "properties": {
        "detected": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 5
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
